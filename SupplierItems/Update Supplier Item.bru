meta {
  name: Update Supplier Item
  type: http
  seq: 1
}

put {
  url: {{baseUrl}}/items/1
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
{
  "branchId": 1,
  "supplierId": 1,
  "itemId": 1,
  "unitId": 1,
  "defaultCostPrice": 520,
  "lastPurchaseCost": 520,
  "isPreferred": true,
  "isActive": true
}
}
