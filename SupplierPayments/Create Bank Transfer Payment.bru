meta {
  name: Create Bank Transfer Payment
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/payments
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
{
  "branchId": 1,
  "supplierId": 1,
  "supplyId": 1,
  "amount": 2000,
  "paymentMethod": "BANK_TRANSFER",
  "paidBy": 1,
  "referenceNo": "TXN001",
  "note": "Partial supplier payment"
}
}
