meta {
  name: Create Cheque Payment
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/payments
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
{
  "branchId": 1,
  "supplierId": 1,
  "supplyId": 1,
  "amount": 3000,
  "paymentMethod": "CHEQUE",
  "paidBy": 1,
  "referenceNo": "CHQ-00045",
  "note": "Cheque payment"
}
}
