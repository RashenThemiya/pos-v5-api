meta {
  name: Create Cash Payment
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/payments
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
{
  "branchId": 1,
  "supplierId": 1,
  "supplyId": 1,
  "amount": 3000,
  "paymentMethod": "CASH",
  "cashSessionId": 1,
  "paidBy": 1,
  "referenceNo": "CASH001",
  "note": "Cash payment"
}
}
